APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_SERVICE=app

LOG_CHANNEL=promtail
SAIL_XDEBUG_MODE=coverage

DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=storeapp
DB_USERNAME=sail
DB_PASSWORD=password

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_UI=8025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@your-app.com"
MAIL_FROM_NAME="${APP_NAME}"

MINIO_ROOT_USER=sail
MINIO_ROOT_PASSWORD=password
MINIO_ENDPOINT=http://localhost:9010
FORWARD_MINIO_PORT=9010
FORWARD_MINIO_CONSOLE_PORT=8900
AWS_URL=http://localhost:9010/laravel-minio

NGROK_AUTHTOKEN=
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
PADDLE_ENV=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_CLIENT_TOKEN=

QUEUE_CONNECTION=rabbitmq
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
